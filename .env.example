# ATLAB Platform — Environment Variables
# Copie para .env e preencha os valores reais

# ─── Database ──────────────────────────────────────────────
DB_PASSWORD=troque-esta-senha-forte

# ─── Authentik OIDC ────────────────────────────────────────
# Criar provider em: Authentik > Applications > Providers > OAuth2/OIDC
# Redirect URI: https://atlab.ufc.br/auth/callback
AUTHENTIK_CLIENT_ID=atlab-platform
AUTHENTIK_CLIENT_SECRET=seu-client-secret-aqui

# ─── JWT (gere com: openssl rand -hex 32) ──────────────────
JWT_SECRET=troque-por-random-hex-64-chars

# ─── Proxmox API Token ─────────────────────────────────────
# Criar em: Proxmox > Datacenter > Permissions > API Tokens
# Formato: user@realm!tokenid
PROXMOX_TOKEN_ID=root@pam!atlab
PROXMOX_TOKEN_SECRET=seu-token-uuid-aqui

# ─── Notificações (opcional) ───────────────────────────────
EVOLUTION_API_URL=http://evolution.atlab.ufc.br:8080
EVOLUTION_API_KEY=sua-apikey
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=-1001234567890
